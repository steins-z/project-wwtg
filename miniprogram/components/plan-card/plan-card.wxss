/* components/plan-card/plan-card.wxss */
.plan-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin: 16rpx 0;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  transform: translateY(40rpx);
  opacity: 0;
  transition: transform 0.3s ease-out, opacity 0.3s ease-out;
}

.plan-card.animate-in {
  transform: translateY(0);
  opacity: 1;
}

.source-badge {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background-color: #FFF5F0;
  color: #FF6B35;
  margin-bottom: 12rpx;
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.card-emoji {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.card-desc {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 16rpx;
}

.card-meta {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 16rpx;
}

.meta-item {
  font-size: 24rpx;
  color: #999;
  margin-right: 24rpx;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  flex: 1;
}

.tag {
  font-size: 22rpx;
  color: #FF6B35;
  background-color: rgba(255, 107, 53, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

.card-stats {
  display: flex;
  gap: 16rpx;
  flex-shrink: 0;
}

.stat {
  font-size: 22rpx;
  color: #999;
}
