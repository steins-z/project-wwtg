/* pages/plan-detail/plan-detail.wxss */
.detail-container {
  padding: 30rpx;
  padding-bottom: 60rpx;
}

.detail-header {
  margin-bottom: 40rpx;
}

.detail-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
  display: block;
  color: #333;
}

/* Timeline */
.stops-section {
  margin-bottom: 40rpx;
}

.timeline {
  padding-left: 8rpx;
}

.timeline-item {
  display: flex;
  position: relative;
  min-height: 160rpx;
}

.timeline-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 40rpx;
  flex-shrink: 0;
}

.timeline-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background-color: #FF6B35;
  border: 4rpx solid #FFF0E8;
  flex-shrink: 0;
  margin-top: 6rpx;
}

.timeline-line {
  width: 4rpx;
  flex: 1;
  background-color: #FFD4C0;
  margin: 8rpx 0;
}

.timeline-content {
  flex: 1;
  padding-left: 20rpx;
  padding-bottom: 32rpx;
}

.stop-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.stop-time {
  font-size: 28rpx;
  color: #FF6B35;
  font-weight: bold;
  margin-right: 16rpx;
  min-width: 80rpx;
}

.stop-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.stop-duration {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.stop-rec {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 12rpx;
  line-height: 1.5;
}

.nav-btn {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  background-color: #FF6B35;
  color: #fff;
  border-radius: 24rpx;
  font-size: 24rpx;
  margin-bottom: 12rpx;
}

.walk-info {
  font-size: 24rpx;
  color: #999;
  padding: 8rpx 0;
  border-top: 1rpx dashed #eee;
  margin-top: 8rpx;
}

/* Tips */
.tips-section {
  margin-bottom: 40rpx;
  background-color: #FFF9F5;
  border-radius: 16rpx;
  padding: 24rpx;
}

.tip-item {
  display: flex;
  padding: 8rpx 0;
}

.tip-dot {
  color: #FF6B35;
  margin-right: 12rpx;
  font-size: 26rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #666;
  flex: 1;
  line-height: 1.5;
}

/* Sources */
.sources-section {
  margin-bottom: 40rpx;
}

.source-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.source-title {
  font-size: 26rpx;
  color: #666;
  flex: 1;
}

.source-likes {
  font-size: 24rpx;
  color: #999;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.loading-view {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 60vh;
  color: #999;
}
