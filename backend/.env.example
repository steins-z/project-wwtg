# ============================================
# 周末搭子 MVP — 环境变量配置
# 使用方法：复制此文件为 .env，填入真实值
#   cp .env.example .env
# ============================================

# --- 应用 ---
# APP_NAME=周末搭子    # Application display name (default: 周末搭子)

# --- 数据库 ---
# PostgreSQL 连接串 (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://wwtg:wwtg@localhost:5432/wwtg

# --- Redis ---
# 用于会话缓存 (MVP 暂未启用，预留)
REDIS_URL=redis://localhost:6379/0

# --- LLM (DeepSeek V3) ---
# 留空则使用 mock 回退，无需 API key 即可启动
LLM_API_KEY=<your-deepseek-key-here>
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# --- 微信小程序 ---
WX_APP_ID=<your-wechat-appid-here>
WX_APP_SECRET=<your-wechat-secret-here>

# --- 高德地图 (地理编码 + 天气 + 路径规划) ---
AMAP_API_KEY=<your-amap-key-here>

# --- Analytics ---
# 分析事件日志目录 (默认 logs/)
# ANALYTICS_LOG_DIR=logs

# --- 天气 (备选: 和风天气, 默认用高德天气 API) ---
# WEATHER_API_KEY=<your-weather-key-here>
