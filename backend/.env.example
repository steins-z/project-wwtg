# ============================================
# 周末搭子 MVP — 环境变量配置
# 使用方法：复制此文件为 .env，填入真实值
#   cp .env.example .env
# ============================================

# --- 数据库 ---
DATABASE_URL=postgresql+asyncpg://wwtg:wwtg@localhost:5432/wwtg

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- LLM (DeepSeek V3) ---
DEEPSEEK_API_KEY=<your-deepseek-key-here>
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# --- 微信小程序 ---
WECHAT_APP_ID=<your-wechat-appid-here>
WECHAT_APP_SECRET=<your-wechat-secret-here>

# --- 高德地图 (地理编码 + 天气 + 路径规划) ---
AMAP_API_KEY=<your-amap-key-here>

# --- 天气 (备选: 和风天气, 默认用高德天气 API) ---
# QWEATHER_API_KEY=<your-qweather-key-here>
